# Local-only secrets for `wrangler dev`. Copy to `.dev.vars` (gitignored) and fill in.
# In production these are set with `wrangler secret put <NAME>` instead — never committed.
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
GEMINI_API_KEY=
PIXABAY_API_KEY=
PEXELS_API_KEY=

# Optional shared guard token. If set, callers must send it as
# `Authorization: Bearer <token>`. Leave blank to run the worker open.
GATEWAY_TOKEN=
